{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/health", "dest": "/api/index.mjs" },
    { "src": "/api/(.*)", "dest": "/api/index.mjs" },
    { "handle": "filesystem" },
    { "src": "/admin(?:/.*)?", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
